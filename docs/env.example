# =============================================================================
# ENV CENTRALIZADO — Documentos e API do servidor (robôs + site)
# =============================================================================
# Parâmetro único: IP/host do servidor onde rodam a API de arquivos e o
# backend WhatsApp. Altere SERVER_HOST abaixo; as URLs são derivadas dele.
#
# Este arquivo é o ÚNICO lugar onde a URL da API e do WhatsApp são definidas:
# - Robôs (NFe/NFC, NFS, DP guias): usam SERVER_API_URL
# - Frontend: copie SERVER_API_URL e WHATSAPP_API para o .env na RAIZ
# - Servidor (sua API): use SERVER_API_URL como base se precisar de URL absoluta
#
# Portas no servidor:
#   - 3001 = API de arquivos (fiscal, DP guias)
#   - 3010 = Backend WhatsApp (whatsapp-emissor)
# =============================================================================

# IP ou hostname do servidor (ex.: 192.168.50.9 ou servidor.local)
# Com ngrok: use a URL pública como abaixo
SERVER_HOST=plagiaristic-elinore-ungloomily.ngrok-free.dev

# URL base da API de arquivos (sem barra no final)
# Com túnel ngrok:
SERVER_API_URL=https://plagiaristic-elinore-ungloomily.ngrok-free.dev

# Mesmo valor para o frontend (copie para o .env na raiz do projeto)

# WhatsApp (Alteração Empresarial)
# Recomendado: não precisa de WHATSAPP_API no front — o site usa a Edge Function office-server
# (JWT + escritório) e a VM repassa para /api/whatsapp (Bearer = CONNECTOR_SECRET no .env do Servidor).
# Opcional no .env da RAIZ do projeto:
# VITE_WHATSAPP_VIA_OFFICE_SERVER=false
# WHATSAPP_API=https://...  # só se desligar o office-server e apontar túnel direto à porta 3010

# Supabase (frontend e robôs em modo servidor)
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# BTG Empresas - cobranca IR
# Use os mesmos valores tambem nas secrets das Edge Functions do Supabase.
BTG_TOKEN_URL=https://id.btgpactual.com/connect/token
BTG_COLLECTIONS_URL=https://api.empresas.btgpactual.com/SEU_COMPANY_ID/banking/collections
BTG_CLIENT_ID=seu-client-id
BTG_CLIENT_SECRET=seu-client-secret
BTG_SCOPE=openid brn:btg:empresas:banking:collections
BTG_IR_WEBHOOK_URL=https://seu-projeto.supabase.co/functions/v1/btg-ir-webhook
BTG_WEBHOOK_SECRET=seu-segredo-de-webhook
